# --- General Settings ---
# The public URL where Twenty CRM is accessible (e.g., https://crm.stayawesome.app)
SERVER_URL=https://crm.stayawesome.app

# --- Database Settings ---
PG_DATABASE_USER=twenty
PG_DATABASE_PASSWORD=placeholder_db_password_change_me
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=default

# --- Security & Secrets ---
# Create unique random values using: openssl rand -base64 32
APP_SECRET=placeholder_app_secret_at_least_32_characters_long_change_me
ENCRYPTION_KEY=placeholder_encryption_key_at_least_32_characters_long_change_me

# --- Storage Settings ---
STORAGE_TYPE=local

# --- Application Behavior ---
SIGN_UP_DISABLED=true
